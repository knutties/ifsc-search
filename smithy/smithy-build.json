{
    "version": "1.0",
    "sources": ["models"],
    "maven": {
        "dependencies": [
            "software.amazon.smithy:smithy-openapi:1.68.0",
            "software.amazon.smithy.typescript:smithy-aws-typescript-codegen:0.49.1"
        ]
    },
    "plugins": {
        "openapi": {
            "service": "io.knutties.banksearch#BankSearch",
            "protocol": "aws.protocols#restJson1",
